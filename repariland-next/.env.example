# Copia este archivo a .env.local para desarrollo y configura las mismas variables en Vercel (Production).
# Sin al menos un proveedor activo, los formularios responderán 503.

# Destino de cotizaciones y mensajes de contacto
FORM_TO_EMAIL=reparilandia@hotmail.com

# ─── Opción A (recomendada): Resend ───
# Crea la API key en https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Reparilandia <onboarding@resend.dev>
# Tras verificar reparilandia.com en Resend:
# RESEND_DOMAIN_VERIFIED=true
# RESEND_FROM_EMAIL=Reparilandia <cotizaciones@reparilandia.com>

# ─── Opción B: Outlook/Hotmail OAuth (Graph) ───
# Microsoft desactivó SMTP con contraseña de aplicación en cuentas personales (error 535 5.7.139).
# 1. Azure → App registrations → Personal Microsoft accounts only
# 2. Permisos delegados: Mail.Send, User.Read, offline_access
# 3. Client secret → OUTLOOK_CLIENT_SECRET
# 4. node scripts/outlook-oauth-setup.cjs → OUTLOOK_REFRESH_TOKEN
# OUTLOOK_CLIENT_ID=tu-client-id
# OUTLOOK_CLIENT_SECRET=tu-client-secret
# OUTLOOK_REFRESH_TOKEN=obtenido-con-el-script
# OUTLOOK_MAILBOX=reparilandia@hotmail.com

# ─── Opción C (legacy): SMTP contraseña ───
# Solo funciona si Microsoft aún permite basic auth en la cuenta (cada vez más raro en @hotmail.com).
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=reparilandia@hotmail.com
# SMTP_PASS=contraseña_de_aplicación
