{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "reparilandia.com" }],
      "destination": "https://www.reparilandia.com/:path*",
      "permanent": true
    }
  ]
}
